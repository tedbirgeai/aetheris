# --- Aetheris Gateway v0.3a ornek konfigurasyon ---
# .env olarak kopyalayin, gercek degerlerle doldurun. .env ASLA commit edilmez.

AETHERIS_LISTEN=:8080

# Bicim: clientID:apiKey,clientID2:apiKey2   (anahtar en az 32 karakter)
# Uretmek icin: openssl rand -hex 24
AETHERIS_API_KEYS=acme:BURAYA_32_KARAKTERDEN_UZUN_ANAHTAR

# Makbuz imza anahtari (64 hex). Uretmek icin: openssl rand -hex 32
# UYARI: Uretimde KALICI olmalidir; degisirse eski makbuzlar dogrulanamaz.
AETHERIS_RECEIPT_SECRET=

# --- Kalicilik ---
# memory   : hizli, bagimlilik yok, YENIDEN BASLATMADA VERI KAYBOLUR
# postgres : kalici defter, faturalama icin ZORUNLU
AETHERIS_STORE=memory
AETHERIS_DATABASE_DSN=postgres://aetheris:aetheris@localhost:5432/aetheris?sslmode=disable

# --- v0.3a: WAL dayanikli kuyruk ---
# true ise: kayitlar ONCE diske yazilir, SONRA asenkron olarak Postgres'e
# basilir. Veritabani duserse tunel trafigi BLOKLANMAZ, kayit kaybolmaz.
AETHERIS_WAL_ENABLED=false
AETHERIS_WAL_DIR=./wal

# --- v0.3a: Dagitik rate limiter ---
# Bos ise bellek-ici (tek dugum) limiter kullanilir.
# Tanimliysa Redis tabanli ORTAK limit; cok dugumlu dagitim icin gerekli.
# Redis duserse otomatik bellek-ici fallback devreye girer.
AETHERIS_REDIS_ADDR=
AETHERIS_REDIS_PASSWORD=
AETHERIS_REDIS_DB=0

# --- v0.3a: Rota saglik kontrolu ve failover ---
# true ise upstream'ler periyodik yoklanir; sagliksiz dugum trafigi
# yedek rotaya veya direct hatta dusurulur.
AETHERIS_HEALTHPROBE=false
AETHERIS_HEALTHPROBE_INTERVAL_SEC=10

# --- Yonlendirme ---
# Bicim: ad=tur@url[;backup=YEDEK_AD][;health=/yol]
#   tur: direct | edge | peering
# Ornek (primary duserse secondary'ye duser, saglik /status'tan yoklanir):
#   AETHERIS_ROUTES=primary=edge@https://a.example;backup=secondary;health=/status,secondary=peering@https://b.example
# backup verilmezse ve rota sagliksizsa, "direct" turundeki ilk rotaya dusulur.
AETHERIS_ROUTES=
AETHERIS_FORWARD_TIMEOUT_SEC=20

# --- Sinirlar ---
AETHERIS_MAX_PAYLOAD_BYTES=1048576
AETHERIS_RATE_LIMIT_PER_MIN=600
AETHERIS_RATE_LIMIT_BURST=60
AETHERIS_READ_TIMEOUT_SEC=10
AETHERIS_WRITE_TIMEOUT_SEC=15
AETHERIS_IDLE_TIMEOUT_SEC=60
AETHERIS_SHUTDOWN_GRACE_SEC=15

# ============================================================
#  v0.3b — TICARILESME, GUVENLIK VE GOZLEMLENEBILIRLIK
# ============================================================

# --- TLS sonlandirma ---
# Bos ise gecit DUZ HTTP dinler (yalnizca yerel gelistirme).
# Internete acmadan once ya bunlari doldurun ya da onune TLS
# sonlandiran bir reverse proxy (nginx/Caddy) koyun.
AETHERIS_TLS_CERT=
AETHERIS_TLS_KEY=
# Sertifika dosyasi degisince kac saniyede bir kontrol edilsin.
# Surec yeniden baslatilmadan yeni sertifika devreye girer.
AETHERIS_TLS_RELOAD_SEC=60

# --- mTLS (dugumler / edge / peering arasi) ---
# "" (kapali) | "optional" (sertifika varsa dogrula) | "require" (zorunlu)
# Uretimde dugumler arasi iletisim icin "require" hedeflenmelidir.
AETHERIS_TLS_CLIENT_AUTH=
# Istemci sertifikalarini dogrulayacak CA demeti (mTLS icin ZORUNLU).
AETHERIS_TLS_CLIENT_CA=

# --- Faturalama koprusu ---
# Kendi muhasebe sisteminize webhook (govde HMAC ile imzalanir).
AETHERIS_BILLING_WEBHOOK_URL=
AETHERIS_BILLING_WEBHOOK_SECRET=

# Stripe meter events. UYARI: canli API'ye karsi DOGRULANMAMISTIR;
# uretime almadan once test anahtariyla bir olay gonderip meter'in
# dogru artigini teyit edin.
AETHERIS_STRIPE_API_KEY=
AETHERIS_STRIPE_METER=aetheris_bytes

# e-Fatura entegratoru. UYARI: Turkiye`de tek bir standart e-Fatura
# API`si YOKTUR; her entegratorun (Logo, Uyumsoft, Parasut...) sozlesmesi
# farklidir. Bu uc nokta kendi adaptor servisinize isaret etmelidir.
AETHERIS_EINVOICE_URL=
AETHERIS_EINVOICE_API_KEY=

# --- Role tesvik kredileri ---
# Baskasinin trafigini kendi dugumunden aktaran musteriye, bayt basina
# kazandirilacak FATURA INDIRIM kredisi. Kripto/token DEGILDIR.
# 0 = kredi motoru kapali.
AETHERIS_CREDIT_PER_BYTE=0
# Donem basina kredi tavani (0 = sinirsiz). Sahte trafikle sinirsiz
# indirim toplanmasini engeller.
AETHERIS_CREDIT_MAX_PER_PERIOD=0

# --- Kullanim esikleri ---
# Asildiginda UsageThresholdExceeded olayi uretilir. Her esik icin
# YALNIZCA BIR KEZ. Virgulle ayrilmis bayt degerleri.
AETHERIS_USAGE_THRESHOLDS=

# --- Prometheus metrikleri ---
# Metrikler musteri kimliklerini ve kullanim hacimlerini icerir —
# TICARI OLARAK HASSASTIR. Token zorunludur; token yoksa gecit acilmaz.
AETHERIS_METRICS=false
AETHERIS_METRICS_TOKEN=
